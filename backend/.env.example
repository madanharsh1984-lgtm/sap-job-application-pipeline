# AI Job Automation SaaS - Backend Environment
# Copy this file to .env and fill in the values

# App
APP_NAME=AI Job Automation SaaS
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_automation

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Apify
APIFY_API_TOKEN=

# Bright Data
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_DATASET_ID=
