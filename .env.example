# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — JobAccelerator AI SaaS Platform
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows CMD)
# ═══════════════════════════════════════════════════════════════════════════════

# REQUIRED — used for JWT signing. Set to any random string.
SECRET_KEY=change-me-to-a-random-string

# OPTIONAL — Apify API token for LinkedIn post scraping.
# Leave empty to skip Apify-based job discovery.
APIFY_TOKEN=
